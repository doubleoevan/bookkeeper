    "history": "^1.17.0",
    "immutable": "^3.7.6",
    "isomorphic-fetch": "^2.2.0",
    "keymirror": "^0.1.1",
    "lodash": "^3.10.1",
    "moment": "^2.11.0",
    "normalizr": "^1.4.0",
    "numeral": "^1.5.3",
    "react": "^0.14.3",
    "react-addons-pure-render-mixin": "^0.14.3",
    "react-dom": "^0.14.3",
    "react-fastclick-alt": "^1.0.0",
    "react-google-maps": "^4.7.2",
    "react-redux": "^4.0.5",
    "react-router": "^1.0.2",
