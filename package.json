{
  "name": "bookkeeper",
  "version": "1.0.0",
  "description": "Track your Facebook posts with Bookkeeper",
  "repository": "https://github.com/doubleoevan/bookkeeper",
  "main": "index.js",
  "scripts": {
    "lint": "eslint src && eslint test",
    "test": "mocha --compilers js:babel-core/register --require ./test/test-helper.js --recursive",
    "tdd": "npm run test -- --watch",
    "prestart": "npm run lint",
    "start": "webpack-dev-server --hot --inline",
    "prebuild": "npm run lint",
    "build": "webpack",
    "stats": "webpack --profile --json > stats.json",
    "predeploy": "npm run build",
    "deploy": "surge -p build -d bookkeeper.surge.sh"
  },
  "babel": ".babelrc",
  "jscsConfig": ".eslintrc",
  "author": "Evan Tsao",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^6.2.3",
    "babel-core": "^6.3.26",
    "babel-eslint": "^5.0.0-beta6",
    "babel-loader": "^6.2.0",
    "babel-plugin-syntax-class-properties": "^6.3.13",
    "babel-plugin-syntax-decorators": "^6.3.13",
    "babel-plugin-syntax-object-rest-spread": "^6.3.13",
    "babel-plugin-transform-class-properties": "^6.4.0",
    "babel-plugin-transform-decorators": "^6.4.0",
    "babel-plugin-transform-object-rest-spread": "^6.3.13",
    "babel-plugin-transform-react-constant-elements": "^6.4.0",
    "babel-plugin-transform-react-inline-elements": "^6.4.0",
    "babel-preset-es2015": "^6.3.13",
    "babel-preset-react": "^6.3.13",
    "babel-preset-react-hmre": "^1.0.1",
    "chai": "^3.4.1",
    "chai-immutable": "^1.5.3",
    "clean-webpack-plugin": "^0.1.6",
    "css-loader": "^0.23.1",
    "eslint": "^1.10.3",
    "eslint-config-airbnb": "^2.1.1",
    "eslint-plugin-react": "^3.13.1",
    "extract-text-webpack-plugin": "^1.0.1",
    "file-loader": "^0.8.5",
    "html-webpack-plugin": "^1.7.0",
    "jsdom": "^7.2.1",
    "mocha": "^2.3.4",
    "node-uuid": "^1.4.7",
    "postcss-loader": "^0.8.0",
    "react-hot-loader": "^1.3.0",
    "style-loader": "^0.13.0",
    "stylus-loader": "^1.4.2",
    "supports-color": "^3.1.2",
    "surge": "^0.17.4",
    "url-loader": "^0.5.7",
    "webpack": "^1.12.9",
    "webpack-dev-server": "^1.14.0",
    "webpack-merge": "^0.7.2"
